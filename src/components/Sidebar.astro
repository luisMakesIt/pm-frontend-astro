---
const navItems = [
  { href: '/', label: 'Dashboard' },
  { href: '/projects', label: 'Proyectos' },
  { href: '/requerimientos', label: 'Requerimientos' },
  { href: '/actas', label: 'Actas' },
  { href: '/actividades', label: 'Actividades' },
  { href: '/productos', label: 'Productos' },
  { href: '/bitacora', label: 'Bitácora' },
  { href: '/equipo', label: 'Equipo' },
  { href: '/reportes', label: 'Reportes' },
];
---

<div class="flex">
  <!-- Mobile overlay -->
  <div class="fixed inset-0 z-40 bg-black/50 lg:hidden hidden" id="sidebar-overlay" onclick="document.getElementById('sidebar-mobile')?.classList.add('hidden')"></div>

  <!-- Sidebar toggle (mobile) -->
  <button
    class="lg:hidden fixed top-4 left-4 z-50 p-2 rounded-md bg-white dark:bg-gray-800 shadow-md"
    onclick="
      const sb = document.getElementById('sidebar-mobile');
      const ov = document.getElementById('sidebar-overlay');
      sb?.classList.toggle('hidden');
      ov?.classList.toggle('hidden');
    "
    aria-label="Toggle sidebar"
  >
    <!-- Menu icon SVG -->
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <!-- Sidebar -->
  <aside
    id="sidebar-desktop"
    class="hidden lg:flex flex-col w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 h-screen fixed left-0 top-0 z-30 transition-all duration-300"
  >
    <!-- Logo -->
    <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-200 dark:border-gray-800">
      <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
        <span class="text-white font-bold text-sm">PM</span>
      </div>
      <span class="font-bold text-lg text-gray-900 dark:text-white">PM System</span>
      <button class="ml-auto p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800" onclick="
        const sb = document.getElementById('sidebar-desktop');
        sb?.classList.toggle('w-64');
        sb?.classList.toggle('w-20');
        const labels = sb?.querySelectorAll('.nav-label');
        labels?.forEach(l => l.classList.toggle('hidden'));
      ">
        <!-- ChevronLeft SVG -->
        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
    </div>

    <!-- Primary nav -->
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
      <p class="nav-label text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 mb-2">Principal</p>
      {navItems.map(item => {
        const isActive = Astro.url.pathname === item.href;
        return (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
              ${isActive
                ? 'bg-primary/10 text-primary'
                : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'
              }`}
          >
            <!-- Dashboard SVG for first item, FolderKanban SVG for second -->
            {item.href === '/' ? (
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            ) : (
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            )}
            <span class="nav-label">{item.label}</span>
          </a>
        );
      })}

    </nav>

    <!-- Bottom section -->
    <div class="px-3 py-4 border-t border-gray-200 dark:border-gray-800 space-y-1">
      <button
        onclick="window.__toggleTheme()"
        class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        <!-- Sun SVG (shown in dark mode) -->
        <svg class="w-5 h-5 flex-shrink-0 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <!-- Moon SVG (shown in light mode) -->
        <svg class="w-5 h-5 flex-shrink-0 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <span class="nav-label">Tema</span>
      </button>
      <a
        href="/login"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-red-600 dark:hover:text-red-400 transition-colors"
      >
        <!-- LogOut SVG -->
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        <span class="nav-label">Cerrar sesión</span>
      </a>
    </div>
  </aside>

  <!-- Mobile sidebar -->
  <aside
    id="sidebar-mobile"
    class="fixed top-0 left-0 z-50 w-64 h-screen bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 transform -translate-x-full transition-transform duration-300 lg:hidden"
  >
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-200 dark:border-gray-800">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
          <span class="text-white font-bold text-sm">PM</span>
        </div>
        <span class="font-bold text-lg">PM System</span>
      </div>
      <button onclick="
        document.getElementById('sidebar-mobile')?.classList.add('-translate-x-full');
        document.getElementById('sidebar-overlay')?.classList.add('hidden');
      ">
        <!-- X SVG -->
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <nav class="px-3 py-4 space-y-1">
      {navItems.map(item => {
        const isActive = Astro.url.pathname === item.href;
        return (
          <a href={item.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${isActive ? 'bg-primary/10 text-primary' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800'}`}>
            {item.label}
          </a>
        );
      })}
    </nav>
  </aside>

  <!-- Main content area -->
  <main class="flex-1 lg:ml-64 overflow-y-auto">
    <!-- Top bar -->
    <header class="sticky top-0 z-20 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
      <div class="flex items-center justify-between px-4 lg:px-8 py-4">
        <div>
          <h1 class="text-xl lg:text-2xl font-bold text-gray-900 dark:text-white">
            <slot name="page-title" default="Dashboard" />
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <button
            onclick="window.__toggleTheme()"
            class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <!-- Sun SVG (shown in dark mode) -->
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <!-- Moon SVG (shown in light mode) -->
            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </button>
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center">
            <span class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold">
              A
            </span>
          </div>
        </div>
      </div>
    </header>
    <div class="p-4 lg:p-8">
      <slot />
    </div>
  </main>
</div>

<style>
  .nav-label {
    transition: opacity 0.2s;
  }
</style>
