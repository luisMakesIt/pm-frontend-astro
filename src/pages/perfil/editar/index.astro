---
import Layout from '../../../layouts/Layout.astro';
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const title = 'Actualizar Datos';
---

<Layout title={title}>
  <div class="p-6 space-y-6 max-w-2xl">
    <div>
      <a href="/perfil/" class="text-blue-600 text-sm hover:underline mb-2 inline-block">← Volver al perfil</a>
      <h1 class="text-2xl font-bold">Actualizar Datos</h1>
      <p class="text-gray-500 text-sm mt-1">Modifica tu nombre y email</p>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6">
      <form id="profile-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" id="name" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" id="email" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div id="error-msg" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div id="success-msg" class="hidden text-green-600 text-sm p-3 bg-green-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors">Guardar Cambios</button>
          <a href="/perfil/" class="border px-4 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Cancelar</a>
        </div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ API_BASE }}>
    var API = API_BASE + '/api';
    function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    function getToken() { var t = localStorage.getItem('pm_token'); if (!t) { window.location.href = '/login'; return null; } return t; }

    async function loadProfile() {
      var token = getToken(); if (!token) return;
      try {
        var res = await fetch(API + '/auth/profile', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          document.getElementById('name').value = json.data.name || '';
          document.getElementById('email').value = json.data.email || '';
        }
      } catch(e) {}
    }

    document.getElementById('profile-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken(); if (!token) return;
      var name = document.getElementById('name').value;
      var email = document.getElementById('email').value;
      var errEl = document.getElementById('error-msg');
      var succEl = document.getElementById('success-msg');
      errEl.classList.add('hidden');
      succEl.classList.add('hidden');
      try {
        var res = await fetch(API + '/auth/profile?_method=PUT', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify({ name: name, email: email })
        });
        var json = await res.json();
        if (json.success) {
          succEl.textContent = json.message || 'Perfil actualizado correctamente.';
          succEl.classList.remove('hidden');
          // Update localStorage user
          try {
            var user = JSON.parse(localStorage.getItem('pm_user') || '{}');
            user.name = name; user.email = email;
            localStorage.setItem('pm_user', JSON.stringify(user));
          } catch(e2) {}
          // Update dropdown
          var initialEl = document.getElementById('user-initial');
          var ddNameEl = document.getElementById('dd-user-name');
          var ddEmailEl = document.getElementById('dd-user-email');
          if (initialEl) initialEl.textContent = name.charAt(0).toUpperCase();
          if (ddNameEl) ddNameEl.textContent = name;
          if (ddEmailEl) ddEmailEl.textContent = email;
        } else {
          errEl.textContent = json.message || 'Error al actualizar';
          errEl.classList.remove('hidden');
        }
      } catch(err) {
        errEl.textContent = 'Error de conexión: ' + err.message;
        errEl.classList.remove('hidden');
      }
    });

    loadProfile();
  </script>
</Layout>
