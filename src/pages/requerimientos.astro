---
import Layout from '../layouts/Layout.astro';
const title = 'Requerimientos';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Requerimientos</h1>
        <p class="text-gray-500 text-sm mt-1">Gestiona requerimientos por proyecto</p>
      </div>
      <button onclick="document.getElementById('modal-create').classList.remove('hidden')" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors duration-200">+ Nuevo Requerimiento</button>
    </div>

    <div class="flex gap-3 items-end">
      <div class="flex-1">
        <label class="block text-sm font-medium mb-1">Filtrar por proyecto</label>
        <select id="filter-project" class="w-full px-4 py-2 border rounded-lg" onchange="loadReqs()">
          <option value="">Todos</option>
        </select>
      </div>
    </div>

    <div id="reqs-list" class="space-y-3">
      <p class="text-gray-500 text-sm">Cargando...</p>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="modal-create" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Nuevo Requerimiento</h3>
      <form id="form-create" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Proyecto</label>
          <select name="project_id" id="create-project" required class="w-full px-4 py-2 border rounded-lg"></select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Título</label>
          <input type="text" name="title" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Descripción</label>
          <textarea name="description" rows="3" class="w-full px-4 py-2 border rounded-lg"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Prioridad</label>
          <select name="priority" class="w-full px-4 py-2 border rounded-lg">
            <option value="alta">Alta</option>
            <option value="media" selected>Media</option>
            <option value="baja">Baja</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado</label>
          <select name="status" class="w-full px-4 py-2 border rounded-lg">
            <option value="pendiente" selected>Pendiente</option>
            <option value="en_progreso">En Progreso</option>
            <option value="completado">Completado</option>
            <option value="cancelado">Cancelado</option>
          </select>
        </div>
        <div id="create-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Crear</button>
          <button type="button" onclick="document.getElementById('modal-create').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="modal-edit" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Editar Requerimiento</h3>
      <form id="form-edit" class="space-y-4">
        <input type="hidden" name="id" id="edit-id">
        <input type="hidden" name="project_id" id="edit-project-id">
        <div>
          <label class="block text-sm font-medium mb-1">Título</label>
          <input type="text" name="title" id="edit-title" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Descripción</label>
          <textarea name="description" id="edit-description" rows="3" class="w-full px-4 py-2 border rounded-lg"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Prioridad</label>
          <select name="priority" id="edit-priority" class="w-full px-4 py-2 border rounded-lg">
            <option value="alta">Alta</option>
            <option value="media">Media</option>
            <option value="baja">Baja</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado</label>
          <select name="status" id="edit-status" class="w-full px-4 py-2 border rounded-lg">
            <option value="pendiente">Pendiente</option>
            <option value="en_progreso">En Progreso</option>
            <option value="completado">Completado</option>
            <option value="cancelado">Cancelado</option>
          </select>
        </div>
        <div id="edit-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Guardar</button>
          <button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';
    var allProjects = [];

    function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadProjectsDropdown() {
      var token = getToken(); if (!token) return;
      try {
        var res = await fetch(API + '/projects', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          allProjects = json.data;
          var filterSel = document.getElementById('filter-project');
          var createSel = document.getElementById('create-project');
          json.data.forEach(function(p) {
            var o1 = document.createElement('option'); o1.value = p.id; o1.textContent = p.name; filterSel.appendChild(o1);
            var o2 = document.createElement('option'); o2.value = p.id; o2.textContent = p.name; createSel.appendChild(o2);
          });
        }
      } catch(e) {}
    }

    async function loadReqs() {
      var token = getToken(); if (!token) return;
      var pid = document.getElementById('filter-project').value;
      var container = document.getElementById('reqs-list');
      container.innerHTML = '<p class="text-gray-500 text-sm">Cargando...</p>';
      try {
        var projects = pid ? allProjects.filter(function(p) { return p.id == pid; }) : allProjects;
        var allReqs = [];
        for (var i = 0; i < projects.length; i++) {
          var res = await fetch(API + '/projects/' + projects[i].id + '/requirements', {
            headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
          });
          var json = await res.json();
          if (json.success && json.data) {
            var reqs = Array.isArray(json.data) ? json.data : [json.data];
            reqs.forEach(function(r) { r.project_name = projects[i].name; r.project_id = projects[i].id; });
            allReqs = allReqs.concat(reqs);
          }
        }
        if (allReqs.length === 0) { container.innerHTML = '<p class="text-gray-500 text-sm">No hay requerimientos.</p>'; return; }
        container.innerHTML = allReqs.map(function(r) {
          var pc = { alta: 'bg-red-100 text-red-700', media: 'bg-yellow-100 text-yellow-700', baja: 'bg-green-100 text-green-700' }[r.priority] || 'bg-gray-100 text-gray-700';
          var sc = { completado: 'bg-green-100 text-green-700', en_progreso: 'bg-blue-100 text-blue-700', pendiente: 'bg-yellow-100 text-yellow-700', cancelado: 'bg-red-100 text-red-700' }[r.status] || 'bg-gray-100 text-gray-700';
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">' +
            '<div class="flex items-start justify-between mb-2">' +
            '<div><h4 class="font-medium">' + esc(r.title) + '</h4>' +
            '<p class="text-xs text-gray-400">Proyecto: ' + esc(r.project_name) + '</p></div>' +
            '<div class="flex gap-1"><span class="' + pc + ' text-xs px-2 py-1 rounded">' + esc(r.priority) + '</span>' +
            '<span class="' + sc + ' text-xs px-2 py-1 rounded">' + esc(r.status) + '</span></div></div>' +
            '<p class="text-sm text-gray-500 mb-2">' + esc(r.description) + '</p>' +
            '<div class="flex gap-2">' +
            '<a href="/actividades" class="text-blue-600 text-sm hover:underline">Ver actividades</a>' +
            '<button onclick="editReq(' + r.id + ',' + r.project_id + ')" class="text-gray-600 text-sm hover:underline">Editar</button>' +
            '<button onclick="deleteReq(' + r.id + ',' + r.project_id + ')" class="text-red-600 text-sm hover:underline">Eliminar</button>' +
            '</div></div>';
        }).join('');
      } catch(e) { container.innerHTML = '<p class="text-red-500 text-sm">Error al cargar</p>'; }
    }

    document.getElementById('form-create').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken(); if (!token) return;
      var d = {}; new FormData(this).forEach(function(v,k){ d[k]=v; });
      var errEl = document.getElementById('create-error');
      try {
        var res = await fetch(API + '/projects/' + d.project_id + '/requirements', {
          method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
        });
        var json = await res.json();
        if (json.success) { document.getElementById('modal-create').classList.add('hidden'); this.reset(); loadReqs(); }
        else { errEl.textContent = json.message || 'Error'; errEl.classList.remove('hidden'); }
      } catch(err) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    async function editReq(id, pid) {
      var token = getToken(); if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + pid + '/requirements/' + id, { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          var r = json.data;
          document.getElementById('edit-id').value = r.id;
          document.getElementById('edit-project-id').value = pid;
          document.getElementById('edit-title').value = r.title || '';
          document.getElementById('edit-description').value = r.description || '';
          document.getElementById('edit-priority').value = r.priority || 'media';
          document.getElementById('edit-status').value = r.status || 'pendiente';
          document.getElementById('modal-edit').classList.remove('hidden');
        }
      } catch(e) { alert('Error al cargar'); }
    }

    document.getElementById('form-edit').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken(); if (!token) return;
      var id = document.getElementById('edit-id').value;
      var pid = document.getElementById('edit-project-id').value;
      var d = {}; new FormData(this).forEach(function(v,k){ if(k!=='id'&&k!=='project_id') d[k]=v; });
      var errEl = document.getElementById('edit-error');
      try {
        var res = await fetch(API + '/requirements/' + id + '?_method=PUT', {
          method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
        });
        var json = await res.json();
        if (json.success) { document.getElementById('modal-edit').classList.add('hidden'); loadReqs(); }
        else { errEl.textContent = json.message || 'Error'; errEl.classList.remove('hidden'); }
      } catch(err) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    async function deleteReq(id, pid) {
      if (!confirm('¿Eliminar requerimiento?')) return;
      var token = getToken(); if (!token) return;
      try { await fetch(API + '/projects/' + pid + '/requirements/' + id, { method: 'DELETE', headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } }); loadReqs(); }
      catch(e) { alert('Error'); }
    }

    loadProjectsDropdown().then(loadReqs);
  </script>
</Layout>
