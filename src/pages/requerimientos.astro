---
import Layout from '../layouts/Layout.astro';
const title = 'Requerimientos';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Requerimientos</h1>
      <p class="text-gray-500 text-sm mt-1">Listado general de requerimientos</p>
    </div>

    <div class="flex gap-3 items-end">
      <div class="flex-1">
        <label class="block text-sm font-medium mb-1">Filtrar por proyecto</label>
        <select id="filter-project" class="w-full px-4 py-2 border rounded-lg">
          <option value="">Todos</option>
        </select>
      </div>
      <button onclick="loadReqs()" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700">Buscar</button>
    </div>

    <div id="reqs-list" class="space-y-3">
      <p class="text-gray-500 text-sm">Cargando requerimientos...</p>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';

    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadProjects() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          var sel = document.getElementById('filter-project');
          json.data.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = p.name || 'Proyecto ' + p.id;
            sel.appendChild(opt);
          });
        }
      } catch(e) {}
    }

    async function loadReqs() {
      var token = getToken();
      if (!token) return;
      var pid = document.getElementById('filter-project').value;
      var container = document.getElementById('reqs-list');
      container.innerHTML = '<p class="text-gray-500 text-sm">Cargando...</p>';

      try {
        var projects = [];
        if (pid) {
          projects = [{ id: pid }];
        } else {
          var pres = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
          var pjson = await pres.json();
          projects = pjson.data || [];
        }

        var allReqs = [];
        for (var i = 0; i < projects.length; i++) {
          var res = await fetch(API + '/projects/' + projects[i].id + '/requirements', {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          var json = await res.json();
          if (json.success && json.data) {
            var reqs = Array.isArray(json.data) ? json.data : [json.data];
            reqs.forEach(function(r) { r.project_name = projects[i].name || 'Proyecto ' + projects[i].id; });
            allReqs = allReqs.concat(reqs);
          }
        }

        if (allReqs.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm">No hay requerimientos.</p>';
          return;
        }

        container.innerHTML = allReqs.map(function(r) {
          var prioColors = { 'alta': 'bg-red-100 text-red-700', 'media': 'bg-yellow-100 text-yellow-700', 'baja': 'bg-green-100 text-green-700' };
          var pc = prioColors[r.priority] || 'bg-gray-100 text-gray-700';
          var status = r.status || 'pendiente';
          var sc = status === 'completado' ? 'bg-green-100 text-green-700' : status === 'en_progreso' ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700';
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4">' +
            '<div class="flex items-start justify-between mb-2">' +
            '<div><h4 class="font-medium">' + (r.title || 'Sin título') + '</h4>' +
            '<p class="text-xs text-gray-400 mt-1">Proyecto: ' + (r.project_name || '-') + '</p></div>' +
            '<div class="flex gap-1"><span class="' + pc + ' text-xs px-2 py-1 rounded">' + (r.priority || 'media') + '</span>' +
            '<span class="' + sc + ' text-xs px-2 py-1 rounded">' + status + '</span></div></div>' +
            '<p class="text-sm text-gray-500 mb-2">' + (r.description || '') + '</p>' +
            '<a href="/actividades" class="text-blue-600 text-sm hover:underline">Ver actividades →</a></div>';
        }).join('');
      } catch(e) {
        container.innerHTML = '<p class="text-red-500 text-sm">Error al cargar requerimientos</p>';
      }
    }

    loadProjects().then(loadReqs);
  </script>
</Layout>
