---
import Layout from '../layouts/Layout.astro';
const title = 'Productos';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Productos</h1>
      <p class="text-gray-500 text-sm mt-1">Productos registrados por actividad</p>
    </div>

    <div id="products-list" class="space-y-3">
      <p class="text-gray-500 text-sm">Cargando productos...</p>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';

    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadProducts() {
      var token = getToken();
      if (!token) return;
      var container = document.getElementById('products-list');

      try {
        var pres = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
        var pjson = await pres.json();
        var projects = pjson.data || [];

        var allProducts = [];

        for (var pi = 0; pi < projects.length; pi++) {
          var rres = await fetch(API + '/projects/' + projects[pi].id + '/requirements', {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          var rjson = await rres.json();
          if (!rjson.success || !rjson.data) continue;
          var reqs = Array.isArray(rjson.data) ? rjson.data : [rjson.data];

          for (var ri = 0; ri < reqs.length; ri++) {
            var ares = await fetch(API + '/requirements/' + reqs[ri].id + '/activities', {
              headers: { 'Authorization': 'Bearer ' + token }
            });
            var ajson = await ares.json();
            if (!ajson.success || !ajson.data) continue;
            var acts = Array.isArray(ajson.data) ? ajson.data : [ajson.data];

            for (var ai = 0; ai < acts.length; ai++) {
              var prres = await fetch(API + '/activities/' + acts[ai].id + '/products', {
                headers: { 'Authorization': 'Bearer ' + token }
              });
              var prjson = await prres.json();
              if (prjson.success && prjson.data) {
                var prods = Array.isArray(prjson.data) ? prjson.data : [prjson.data];
                prods.forEach(function(pr) {
                  pr.act_title = acts[ai].title || 'Actividad ' + acts[ai].id;
                  pr.project_name = projects[pi].name || 'Proyecto ' + projects[pi].id;
                });
                allProducts = allProducts.concat(prods);
              }
            }
          }
        }

        if (allProducts.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm">No hay productos registrados.</p>';
          return;
        }

        container.innerHTML = allProducts.map(function(p) {
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4">' +
            '<div class="flex items-start justify-between mb-2">' +
            '<div><h4 class="font-medium">' + (p.name || p.title || 'Sin nombre') + '</h4>' +
            '<p class="text-xs text-gray-400 mt-1">' + (p.project_name || '') + ' → ' + (p.act_title || '') + '</p></div></div>' +
            '<p class="text-sm text-gray-500">' + (p.description || '') + '</p></div>';
        }).join('');
      } catch(e) {
        container.innerHTML = '<p class="text-red-500 text-sm">Error al cargar productos</p>';
      }
    }

    loadProducts();
  </script>
</Layout>
