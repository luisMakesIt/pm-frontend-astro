---
import Layout from '../layouts/Layout.astro';
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

const title = 'Dashboard';
---

<Layout title={title}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">Vista general del sistema</p>
      </div>
    </div>

    <div id="stats-cards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <p class="text-gray-500 text-sm">Proyectos Totales</p>
        <p class="text-3xl font-bold mt-2" id="stat-projects">-</p>
        <p class="text-green-500 text-xs mt-2" id="stat-projects-detail">Cargando...</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <p class="text-gray-500 text-sm">Requerimientos</p>
        <p class="text-3xl font-bold mt-2" id="stat-reqs">-</p>
        <p class="text-yellow-500 text-xs mt-2" id="stat-reqs-detail">Cargando...</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <p class="text-gray-500 text-sm">Actividades</p>
        <p class="text-3xl font-bold mt-2" id="stat-acts">-</p>
        <p class="text-blue-500 text-xs mt-2" id="stat-acts-detail">Cargando...</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <p class="text-gray-500 text-sm">Miembros de Equipo</p>
        <p class="text-3xl font-bold mt-2" id="stat-team">-</p>
        <p class="text-purple-500 text-xs mt-2">Total registrados</p>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold">Proyectos Recientes</h3>
        <a href="/projects" class="text-blue-600 text-sm hover:underline">Ver todos →</a>
      </div>
      <div id="recent-projects" class="space-y-4">
        <p class="text-gray-500 text-sm">Cargando proyectos...</p>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ API_BASE }}>
    (async function() {
      var token = localStorage.getItem('pm_token');
      if (!token) { window.location.href = '/login'; return; }
      var API = API_BASE + '/api';

      function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
      function el(id) { return document.getElementById(id); }

      try {
        var res = await fetch(API + '/dashboard/stats', {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        if (json.success && json.data) {
          var d = json.data;
          el('stat-projects').textContent = d.total_projects || 0;
          el('stat-projects-detail').textContent = (d.active_projects || 0) + ' activos';
          el('stat-reqs').textContent = d.total_requirements || 0;
          el('stat-reqs-detail').textContent = 'Total registrados';
          el('stat-acts').textContent = d.total_activities || 0;
          el('stat-acts-detail').textContent = 'Total registradas';
        }
      } catch(e) {
        el('stat-projects').textContent = '!';
        el('stat-projects-detail').textContent = 'Error al cargar';
      }

      try {
        var res2 = await fetch(API + '/projects', {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json2 = await res2.json();
        if (json2.success && json2.data) {
          var projects = json2.data;
          var container = el('recent-projects');
          if (projects.length === 0) {
            container.innerHTML = '<p class="text-gray-500 text-sm">No hay proyectos. <a href="/projects" class="text-blue-600 hover:underline">Crear uno</a></p>';
          } else {
            container.innerHTML = projects.slice(0, 5).map(function(p) {
              var status = p.status || 'activo';
              var statusColor = status === 'completado' ? 'bg-green-100 text-green-700' :
                status === 'en_progreso' || status === 'activo' ? 'bg-blue-100 text-blue-700' :
                'bg-yellow-100 text-yellow-700';
              var progress = p.progreso || 0;
              return '<div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">' +
                '<div><h4 class="font-medium">' + esc(p.name || 'Sin nombre') + '</h4>' +
                '<p class="text-sm text-gray-500">' + esc(status) + ' &middot; ' + esc(progress) + '% completado</p></div>' +
                '<span class="' + statusColor + ' text-xs px-2 py-1 rounded">' + esc(status) + '</span></div>';
            }).join('');
          }
        }
      } catch(e) {
        el('recent-projects').innerHTML = '<p class="text-red-500 text-sm">Error al cargar proyectos</p>';
      }
    })();
  </script>
</Layout>
