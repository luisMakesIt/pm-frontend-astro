---
import Layout from '../layouts/Layout.astro';
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const title = 'Actas';
---

<Layout title={title}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Actas de Requerimientos</h1>
        <p class="text-gray-500 text-sm mt-1">Actas de toma de requerimientos</p>
      </div>
      <button onclick="document.getElementById('modal-create').classList.remove('hidden')" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors duration-200">+ Nueva Acta</button>
    </div>

    <div id="actas-list" class="space-y-3">
      <p class="text-gray-500 text-sm">Cargando...</p>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="modal-create" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-bold mb-4">Nueva Acta</h3>
      <form id="form-create" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Requerimiento</label>
          <select name="requirement_id" id="create-req" required class="w-full px-4 py-2 border rounded-lg"></select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Fecha de Sesión</label>
          <input type="date" name="fecha_sesion" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Nombre del Cliente</label>
          <input type="text" name="cliente_nombre" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email del Cliente</label>
          <input type="email" name="cliente_email" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Empresa del Cliente</label>
          <input type="text" name="cliente_empresa" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Participantes (separados por comas)</label>
          <input type="text" name="participantes" placeholder="Juan, Maria, Pedro" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Notas</label>
          <textarea name="notas" rows="3" class="w-full px-4 py-2 border rounded-lg"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Acuerdos (separados por comas)</label>
          <input type="text" name="acuerdos" placeholder="Acuerdo 1, Acuerdo 2" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado de Firma</label>
          <select name="estado_firma" class="w-full px-4 py-2 border rounded-lg">
            <option value="sin_firmar" selected>Sin Firmar</option>
            <option value="esperando_firma">Esperando Firma</option>
            <option value="firmado">Firmado</option>
            <option value="archivado">Archivado</option>
          </select>
        </div>
        <div id="create-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Crear</button>
          <button type="button" onclick="document.getElementById('modal-create').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="modal-edit" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-bold mb-4">Editar Acta</h3>
      <form id="form-edit" class="space-y-4">
        <input type="hidden" name="id" id="edit-id">
        <input type="hidden" name="requirement_id" id="edit-req-id">
        <div><label class="block text-sm font-medium mb-1">Fecha Sesión</label><input type="date" name="fecha_sesion" id="edit-fecha" class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Nombre Cliente</label><input type="text" name="cliente_nombre" id="edit-nombre" required class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Email Cliente</label><input type="email" name="cliente_email" id="edit-email" required class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Empresa</label><input type="text" name="cliente_empresa" id="edit-empresa" required class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Participantes</label><input type="text" name="participantes" id="edit-part" class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Notas</label><textarea name="notas" id="edit-notas" rows="3" class="w-full px-4 py-2 border rounded-lg"></textarea></div>
        <div><label class="block text-sm font-medium mb-1">Estado Firma</label><select name="estado_firma" id="edit-estado" class="w-full px-4 py-2 border rounded-lg"><option value="sin_firmar">Sin Firmar</option><option value="esperando_firma">Esperando</option><option value="firmado">Firmado</option><option value="archivado">Archivado</option></select></div>
        <div id="edit-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3"><button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Guardar</button><button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button></div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ API_BASE }}>
    var API = API_BASE + '/api';
    var allReqs = [];

    function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    function getToken() { var t = localStorage.getItem('pm_token'); if (!t) { window.location.href = '/login'; return null; } return t; }

    async function loadReqsForDropdown() {
      var token = getToken(); if (!token) return;
      try {
        var pres = await fetch(API + '/projects', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
        var pjson = await pres.json();
        var projects = pjson.data || [];
        for (var i = 0; i < projects.length; i++) {
          var res = await fetch(API + '/projects/' + projects[i].id + '/requirements', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
          var json = await res.json();
          if (json.success && json.data) {
            var reqs = Array.isArray(json.data) ? json.data : [json.data];
            reqs.forEach(function(r) { r.project_name = projects[i].name; });
            allReqs = allReqs.concat(reqs);
          }
        }
        var sel = document.getElementById('create-req');
        allReqs.forEach(function(r) { var o = document.createElement('option'); o.value = r.id; o.textContent = r.title + ' (' + r.project_name + ')'; sel.appendChild(o); });
      } catch(e) {}
    }

    async function loadActas() {
      var token = getToken(); if (!token) return;
      var container = document.getElementById('actas-list');
      container.innerHTML = '<p class="text-gray-500 text-sm">Cargando...</p>';
      try {
        var allActas = [];
        for (var i = 0; i < allReqs.length; i++) {
          var res = await fetch(API + '/requirements/' + allReqs[i].id + '/actas', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
          var json = await res.json();
          if (json.success && json.data) {
            var actas = Array.isArray(json.data) ? json.data : [json.data];
            actas.forEach(function(a) { a.req_title = allReqs[i].title; a.req_id = allReqs[i].id; a.project_name = allReqs[i].project_name; });
            allActas = allActas.concat(actas);
          }
        }
        if (allActas.length === 0) { container.innerHTML = '<p class="text-gray-500 text-sm">No hay actas.</p>'; return; }
        var sc = { firmado: 'bg-green-100 text-green-700', esperando_firma: 'bg-yellow-100 text-yellow-700', sin_firmar: 'bg-red-100 text-red-700', archivado: 'bg-gray-100 text-gray-700' };
        container.innerHTML = allActas.map(function(a) {
          var parts = Array.isArray(a.participantes) ? a.participantes.map(function(p){return esc(p);}).join(', ') : esc(a.participantes);
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">' +
            '<div class="flex items-start justify-between mb-2">' +
            '<div><h4 class="font-medium">Acta #' + esc(a.id) + '</h4>' +
            '<p class="text-xs text-gray-400">' + esc(a.project_name) + ' &rarr; ' + esc(a.req_title) + '</p></div>' +
            '<span class="' + (sc[a.estado_firma]||'bg-gray-100 text-gray-700') + ' text-xs px-2 py-1 rounded">' + esc(a.estado_firma) + '</span></div>' +
            '<div class="text-sm space-y-1">' +
            (a.cliente_nombre ? '<p><strong>Cliente:</strong> ' + esc(a.cliente_nombre) + ' (' + esc(a.cliente_empresa) + ')</p>' : '') +
            (a.fecha_sesion ? '<p><strong>Fecha:</strong> ' + esc((a.fecha_sesion||'').split('T')[0]) + '</p>' : '') +
            (parts ? '<p><strong>Participantes:</strong> ' + parts + '</p>' : '') +
            (a.notas ? '<p><strong>Notas:</strong> ' + esc(a.notas) + '</p>' : '') +
            '</div>' +
            '<div class="flex flex-wrap gap-2 mt-3">' +
            '<button onclick="editActa(' + a.id + ',' + a.req_id + ')" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' +
            'Editar</button>' +
            '<a href="/actas/preview/?id=' + a.id + '&req_id=' + a.req_id + '" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 bg-blue-50 dark:bg-blue-900/30 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>' +
            'Previsualizar</a>' +
            '<button onclick="downloadPdf(' + a.id + ',' + a.req_id + ')" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-green-600 bg-green-50 dark:bg-green-900/30 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/50 transition-colors">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>' +
            'Descargar PDF</button>' +
            '<button onclick="deleteActa(' + a.id + ',' + a.req_id + ')" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 dark:bg-red-900/30 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/50 transition-colors">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>' +
            'Eliminar</button>' +
            '</div></div>';
        }).join('');
      } catch(e) { container.innerHTML = '<p class="text-red-500 text-sm">Error</p>'; }
    }

    document.getElementById('form-create').addEventListener('submit', async function(e) {
      e.preventDefault(); var token = getToken(); if (!token) return;
      var d = {}; new FormData(this).forEach(function(v,k){
        if (k === 'participantes' || k === 'acuerdos') { d[k] = v ? v.split(',').map(function(s){return s.trim();}) : []; }
        else d[k] = v;
      });
      var errEl = document.getElementById('create-error');
      var res = await fetch(API + '/requirements/' + d.requirement_id + '/actas', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
      });
      var json = await res.json();
      if (json.success) { document.getElementById('modal-create').classList.add('hidden'); this.reset(); loadActas(); }
      else { errEl.textContent = json.message || 'Error'; errEl.classList.remove('hidden'); }
    });

    async function editActa(id, rid) {
      var token = getToken(); if (!token) return;
      var res = await fetch(API + '/requirements/' + rid + '/actas/' + id, { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
      var json = await res.json();
      if (json.success && json.data) {
        var a = json.data;
        document.getElementById('edit-id').value = a.id;
        document.getElementById('edit-req-id').value = rid;
        document.getElementById('edit-fecha').value = (a.fecha_sesion || '').split('T')[0];
        document.getElementById('edit-nombre').value = a.cliente_nombre || '';
        document.getElementById('edit-email').value = a.cliente_email || '';
        document.getElementById('edit-empresa').value = a.cliente_empresa || '';
        document.getElementById('edit-part').value = Array.isArray(a.participantes) ? a.participantes.join(', ') : (a.participantes || '');
        document.getElementById('edit-notas').value = a.notas || '';
        document.getElementById('edit-estado').value = a.estado_firma || 'sin_firmar';
        document.getElementById('modal-edit').classList.remove('hidden');
      }
    }

    document.getElementById('form-edit').addEventListener('submit', async function(e) {
      e.preventDefault(); var token = getToken(); if (!token) return;
      var id = document.getElementById('edit-id').value; var rid = document.getElementById('edit-req-id').value;
      var d = {}; new FormData(this).forEach(function(v,k){
        if (k === 'participantes') { d[k] = v ? v.split(',').map(function(s){return s.trim();}) : []; }
        else if (k !== 'id' && k !== 'requirement_id') d[k] = v;
      });
      var res = await fetch(API + '/requirements/' + rid + '/actas/' + id + '?_method=PUT', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
      });
      var json = await res.json();
      if (json.success) { document.getElementById('modal-edit').classList.add('hidden'); loadActas(); }
      else { document.getElementById('edit-error').textContent = json.message || 'Error'; document.getElementById('edit-error').classList.remove('hidden'); }
    });

    async function deleteActa(id, rid) {
      if (!confirm('¿Eliminar acta?')) return;
      var token = getToken(); if (!token) return;
      await fetch(API + '/requirements/' + rid + '/actas/' + id, { method: 'DELETE', headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
      loadActas();
    }

    function downloadPdf(id, rid) {
      window.open('/actas/preview/?id=' + id + '&req_id=' + rid + '&print=true', '_blank');
    }

    window.editActa = editActa;
    window.deleteActa = deleteActa;
    window.downloadPdf = downloadPdf;

    loadReqsForDropdown().then(loadActas);
  </script>
</Layout>
