---
import Layout from '../layouts/Layout.astro';
const title = 'Equipo';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Equipo</h1>
      <p class="text-gray-500 text-sm mt-1">Miembros del equipo por proyecto</p>
    </div>

    <div class="flex gap-3 items-end">
      <div class="flex-1">
        <label class="block text-sm font-medium mb-1">Filtrar por proyecto</label>
        <select id="filter-project" class="w-full px-4 py-2 border rounded-lg">
          <option value="">Todos</option>
        </select>
      </div>
      <button onclick="loadMembers()" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700">Buscar</button>
    </div>

    <div id="members-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <p class="text-gray-500 text-sm">Cargando miembros...</p>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';

    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadProjectsDropdown() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          var sel = document.getElementById('filter-project');
          json.data.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = p.name || 'Proyecto ' + p.id;
            sel.appendChild(opt);
          });
        }
      } catch(e) {}
    }

    async function loadMembers() {
      var token = getToken();
      if (!token) return;
      var pid = document.getElementById('filter-project').value;
      var container = document.getElementById('members-list');
      container.innerHTML = '<p class="text-gray-500 text-sm">Cargando...</p>';

      try {
        var projects = [];
        if (pid) {
          var pres = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
          var pjson = await pres.json();
          projects = (pjson.data || []).filter(function(p) { return p.id == pid; });
        } else {
          var pres2 = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
          var pjson2 = await pres2.json();
          projects = pjson2.data || [];
        }

        var allMembers = [];

        for (var i = 0; i < projects.length; i++) {
          var res = await fetch(API + '/projects/' + projects[i].id + '/team-members', {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          var json = await res.json();
          if (json.success && json.data) {
            var members = Array.isArray(json.data) ? json.data : [json.data];
            members.forEach(function(m) { m.project_name = projects[i].name || 'Proyecto ' + projects[i].id; });
            allMembers = allMembers.concat(members);
          }
        }

        if (allMembers.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm">No hay miembros registrados.</p>';
          return;
        }

        var roleColors = {
          'developer': 'bg-blue-100 text-blue-700',
          'tech_lead': 'bg-purple-100 text-purple-700',
          'tester': 'bg-green-100 text-green-700',
          'designer': 'bg-pink-100 text-pink-700'
        };

        container.innerHTML = allMembers.map(function(m) {
          var rc = roleColors[m.role] || 'bg-gray-100 text-gray-700';
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4">' +
            '<div class="flex items-center gap-3">' +
            '<div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">' + (m.name || '?').charAt(0).toUpperCase() + '</div>' +
            '<div><h4 class="font-medium">' + (m.name || 'Sin nombre') + '</h4>' +
            '<p class="text-sm text-gray-500">' + (m.email || '') + '</p></div></div>' +
            '<div class="mt-2"><p class="text-xs text-gray-400">Proyecto: ' + (m.project_name || '-') + '</p></div>' +
            '<div class="mt-3"><span class="' + rc + ' text-xs px-2 py-1 rounded">' + (m.role || '-') + '</span></div></div>';
        }).join('');
      } catch(e) {
        container.innerHTML = '<p class="text-red-500 text-sm">Error al cargar miembros</p>';
      }
    }

    loadProjectsDropdown().then(loadMembers);
  </script>
</Layout>
