---
import Layout from '../layouts/Layout.astro';
const title = 'Equipo';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Equipo</h1>
        <p class="text-gray-500 text-sm mt-1">Miembros del equipo por proyecto</p>
      </div>
      <button onclick="document.getElementById('modal-create').classList.remove('hidden')" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors duration-200">+ Nuevo Miembro</button>
    </div>

    <div class="flex gap-3 items-end">
      <div class="flex-1">
        <label class="block text-sm font-medium mb-1">Filtrar por proyecto</label>
        <select id="filter-project" class="w-full px-4 py-2 border rounded-lg" onchange="loadMembers()">
          <option value="">Todos</option>
        </select>
      </div>
    </div>

    <div id="members-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <p class="text-gray-500 text-sm">Cargando miembros...</p>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="modal-create" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-bold mb-4">Nuevo Miembro del Equipo</h3>
      <form id="form-create" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Proyecto</label>
          <select name="project_id" id="create-project" required class="w-full px-4 py-2 border rounded-lg"></select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Rol</label>
          <select name="role" class="w-full px-4 py-2 border rounded-lg">
            <option value="developer">Developer</option>
            <option value="designer">Designer</option>
            <option value="tester">Tester</option>
            <option value="tech_lead">Tech Lead</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Nivel de Experiencia</label>
          <select name="nivel_experiencia" class="w-full px-4 py-2 border rounded-lg">
            <option value="">Sin especificar</option>
            <option value="junior">Junior</option>
            <option value="middle">Middle</option>
            <option value="senior">Senior</option>
            <option value="lead">Lead</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado</label>
          <select name="estado" class="w-full px-4 py-2 border rounded-lg">
            <option value="disponible" selected>Disponible</option>
            <option value="en_tarea">En Tarea</option>
            <option value="ocupado">Ocupado</option>
            <option value="fuera">Fuera</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Git Username</label>
          <input type="text" name="git_username" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div id="create-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Crear</button>
          <button type="button" onclick="document.getElementById('modal-create').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="modal-edit" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-bold mb-4">Editar Miembro</h3>
      <form id="form-edit" class="space-y-4">
        <input type="hidden" name="id" id="edit-id">
        <input type="hidden" name="project_id" id="edit-project-id">
        <div><label class="block text-sm font-medium mb-1">Nombre</label><input type="text" name="name" id="edit-name" required class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Email</label><input type="email" name="email" id="edit-email" required class="w-full px-4 py-2 border rounded-lg"></div>
        <div><label class="block text-sm font-medium mb-1">Rol</label><select name="role" id="edit-role" class="w-full px-4 py-2 border rounded-lg"><option value="developer">Developer</option><option value="designer">Designer</option><option value="tester">Tester</option><option value="tech_lead">Tech Lead</option></select></div>
        <div><label class="block text-sm font-medium mb-1">Nivel</label><select name="nivel_experiencia" id="edit-nivel" class="w-full px-4 py-2 border rounded-lg"><option value="">Sin especificar</option><option value="junior">Junior</option><option value="middle">Middle</option><option value="senior">Senior</option><option value="lead">Lead</option></select></div>
        <div><label class="block text-sm font-medium mb-1">Estado</label><select name="estado" id="edit-estado" class="w-full px-4 py-2 border rounded-lg"><option value="disponible">Disponible</option><option value="en_tarea">En Tarea</option><option value="ocupado">Ocupado</option><option value="fuera">Fuera</option></select></div>
        <div><label class="block text-sm font-medium mb-1">Git Username</label><input type="text" name="git_username" id="edit-git" class="w-full px-4 py-2 border rounded-lg"></div>
        <div id="edit-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3"><button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700">Guardar</button><button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button></div>
      </form>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';
    var allProjects = [];

    function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    function getToken() { var t = localStorage.getItem('pm_token'); if (!t) { window.location.href = '/login'; return null; } return t; }

    async function loadProjectsDropdown() {
      var token = getToken(); if (!token) return;
      try {
        var res = await fetch(API + '/projects', { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
        var json = await res.json();
        if (json.success && json.data) {
          allProjects = json.data;
          var filterSel = document.getElementById('filter-project');
          var createSel = document.getElementById('create-project');
          json.data.forEach(function(p) {
            var o1 = document.createElement('option'); o1.value = p.id; o1.textContent = p.name; filterSel.appendChild(o1);
            var o2 = document.createElement('option'); o2.value = p.id; o2.textContent = p.name; createSel.appendChild(o2);
          });
        }
      } catch(e) {}
    }

    async function loadMembers() {
      var token = getToken(); if (!token) return;
      var pid = document.getElementById('filter-project').value;
      var container = document.getElementById('members-list');
      container.innerHTML = '<p class="text-gray-500 text-sm">Cargando...</p>';
      var projects = pid ? allProjects.filter(function(p) { return p.id == pid; }) : allProjects;
      var allMembers = [];
      try {
        for (var i = 0; i < projects.length; i++) {
          var res = await fetch(API + '/projects/' + projects[i].id + '/team-members', {
            headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
          });
          var json = await res.json();
          if (json.success && json.data) {
            var members = Array.isArray(json.data) ? json.data : [json.data];
            members.forEach(function(m) { m.project_name = projects[i].name; m.project_id = projects[i].id; });
            allMembers = allMembers.concat(members);
          }
        }
        if (allMembers.length === 0) { container.innerHTML = '<p class="text-gray-500 text-sm">No hay miembros.</p>'; return; }
        var rc = { developer: 'bg-blue-100 text-blue-700', tech_lead: 'bg-purple-100 text-purple-700', tester: 'bg-green-100 text-green-700', designer: 'bg-pink-100 text-pink-700' };
        var sc = { disponible: 'bg-green-100 text-green-700', en_tarea: 'bg-blue-100 text-blue-700', ocupado: 'bg-yellow-100 text-yellow-700', fuera: 'bg-red-100 text-red-700' };
        container.innerHTML = allMembers.map(function(m) {
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">' +
            '<div class="flex items-center gap-3">' +
            '<div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">' + esc((m.name || '?').charAt(0).toUpperCase()) + '</div>' +
            '<div class="flex-1"><h4 class="font-medium">' + esc(m.name) + '</h4>' +
            '<p class="text-sm text-gray-500">' + esc(m.email) + '</p></div></div>' +
            '<div class="mt-2 flex flex-wrap gap-1">' +
            '<span class="' + (rc[m.role]||'bg-gray-100 text-gray-700') + ' text-xs px-2 py-1 rounded">' + esc(m.role) + '</span>' +
            (m.nivel_experiencia ? '<span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">' + esc(m.nivel_experiencia) + '</span>' : '') +
            '<span class="' + (sc[m.estado]||'bg-gray-100 text-gray-700') + ' text-xs px-2 py-1 rounded">' + esc(m.estado) + '</span></div>' +
            '<p class="text-xs text-gray-400 mt-2">Proyecto: ' + esc(m.project_name) + '</p>' +
            '<div class="flex gap-2 mt-2">' +
            '<button onclick="editMember(' + m.id + ',' + m.project_id + ')" class="text-gray-600 text-sm hover:underline">Editar</button>' +
            '<button onclick="deleteMember(' + m.id + ',' + m.project_id + ')" class="text-red-600 text-sm hover:underline">Eliminar</button>' +
            '</div></div>';
        }).join('');
      } catch(e) { container.innerHTML = '<p class="text-red-500 text-sm">Error</p>'; }
    }

    document.getElementById('form-create').addEventListener('submit', async function(e) {
      e.preventDefault(); var token = getToken(); if (!token) return;
      var d = {}; new FormData(this).forEach(function(v,k){ if(v) d[k]=v; });
      var errEl = document.getElementById('create-error');
      var res = await fetch(API + '/projects/' + d.project_id + '/team-members', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
      });
      var json = await res.json();
      if (json.success) { document.getElementById('modal-create').classList.add('hidden'); this.reset(); loadMembers(); }
      else { errEl.textContent = json.message || 'Error'; errEl.classList.remove('hidden'); }
    });

    async function editMember(id, pid) {
      var token = getToken(); if (!token) return;
      var res = await fetch(API + '/projects/' + pid + '/team-members/' + id, { headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
      var json = await res.json();
      if (json.success && json.data) {
        var m = json.data;
        document.getElementById('edit-id').value = m.id;
        document.getElementById('edit-project-id').value = pid;
        document.getElementById('edit-name').value = m.name || '';
        document.getElementById('edit-email').value = m.email || '';
        document.getElementById('edit-role').value = m.role || 'developer';
        document.getElementById('edit-nivel').value = m.nivel_experiencia || '';
        document.getElementById('edit-estado').value = m.estado || 'disponible';
        document.getElementById('edit-git').value = m.git_username || '';
        document.getElementById('modal-edit').classList.remove('hidden');
      }
    }

    document.getElementById('form-edit').addEventListener('submit', async function(e) {
      e.preventDefault(); var token = getToken(); if (!token) return;
      var id = document.getElementById('edit-id').value; var pid = document.getElementById('edit-project-id').value;
      var d = {}; new FormData(this).forEach(function(v,k){ if(k!=='id'&&k!=='project_id'&&v) d[k]=v; });
      var res = await fetch(API + '/projects/' + pid + '/team-members/' + id + '?_method=PUT', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(d)
      });
      var json = await res.json();
      if (json.success) { document.getElementById('modal-edit').classList.add('hidden'); loadMembers(); }
      else { document.getElementById('edit-error').textContent = json.message || 'Error'; document.getElementById('edit-error').classList.remove('hidden'); }
    });

    async function deleteMember(id, pid) {
      if (!confirm('¿Eliminar miembro del equipo?')) return;
      var token = getToken(); if (!token) return;
      await fetch(API + '/projects/' + pid + '/team-members/' + id, { method: 'DELETE', headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token } });
      loadMembers();
    }

    loadProjectsDropdown().then(loadMembers);
  </script>
</Layout>
