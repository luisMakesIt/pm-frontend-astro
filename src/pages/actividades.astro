---
import Layout from '../layouts/Layout.astro';
const title = 'Actividades';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Actividades</h1>
      <p class="text-gray-500 text-sm mt-1">Listado general de actividades por requerimiento</p>
    </div>

    <div id="acts-list" class="space-y-3">
      <p class="text-gray-500 text-sm">Cargando actividades...</p>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';

    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadActivities() {
      var token = getToken();
      if (!token) return;
      var container = document.getElementById('acts-list');

      try {
        var pres = await fetch(API + '/projects', { headers: { 'Authorization': 'Bearer ' + token } });
        var pjson = await pres.json();
        var projects = pjson.data || [];

        var allActs = [];

        for (var pi = 0; pi < projects.length; pi++) {
          var rres = await fetch(API + '/projects/' + projects[pi].id + '/requirements', {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          var rjson = await rres.json();
          if (!rjson.success || !rjson.data) continue;
          var reqs = Array.isArray(rjson.data) ? rjson.data : [rjson.data];

          for (var ri = 0; ri < reqs.length; ri++) {
            var ares = await fetch(API + '/requirements/' + reqs[ri].id + '/activities', {
              headers: { 'Authorization': 'Bearer ' + token }
            });
            var ajson = await ares.json();
            if (ajson.success && ajson.data) {
              var acts = Array.isArray(ajson.data) ? ajson.data : [ajson.data];
              acts.forEach(function(a) {
                a.req_title = reqs[ri].title || 'Req ' + reqs[ri].id;
                a.project_name = projects[pi].name || 'Proyecto ' + projects[pi].id;
              });
              allActs = allActs.concat(acts);
            }
          }
        }

        if (allActs.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm">No hay actividades registradas.</p>';
          return;
        }

        container.innerHTML = allActs.map(function(a) {
          var status = a.status || 'pendiente';
          var sc = status === 'completada' ? 'bg-green-100 text-green-700' : status === 'en_progreso' ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700';
          return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4">' +
            '<div class="flex items-start justify-between mb-2">' +
            '<div><h4 class="font-medium">' + (a.title || 'Sin título') + '</h4>' +
            '<p class="text-xs text-gray-400 mt-1">' + (a.project_name || '') + ' → ' + (a.req_title || '') + '</p></div>' +
            '<span class="' + sc + ' text-xs px-2 py-1 rounded">' + status + '</span></div>' +
            '<p class="text-sm text-gray-500 mb-2">' + (a.description || '') + '</p>' +
            '<a href="/productos" class="text-blue-600 text-sm hover:underline">Ver productos →</a></div>';
        }).join('');
      } catch(e) {
        container.innerHTML = '<p class="text-red-500 text-sm">Error al cargar actividades</p>';
      }
    }

    loadActivities();
  </script>
</Layout>
