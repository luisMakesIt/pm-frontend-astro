---
import Layout from '../layouts/Layout.astro';
import { useParams, Link } from 'astro:container';

const { projectId } = await import('astro:container');

const params = await import.meta.env;
const title = 'Detalle del Proyecto';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <!-- Header with breadcrumbs -->
    <div>
      <nav class="text-sm text-gray-500 mb-2">
        <a href="/" class="hover:text-blue-600">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/projects" class="hover:text-blue-600">Proyectos</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900 dark:text-gray-100">Detalle</span>
      </nav>
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-2xl font-bold">Sistema de Facturación</h1>
          <p class="text-gray-500 text-sm mt-1">Sistema completo de facturación electrónica con integración fiscal (CFDI 4.0)</p>
        </div>
        <div class="flex gap-2">
          <span class="bg-green-100 text-green-700 text-sm px-3 py-1 rounded-full">En Desarrollo</span>
          <button class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 transition">Editar</button>
        </div>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4">
        <p class="text-gray-500 text-xs">Progreso General</p>
        <p class="text-2xl font-bold text-green-600">70%</p>
        <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2">
          <div class="bg-green-500 h-1.5 rounded-full" style="width: 70%"></div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4">
        <p class="text-gray-500 text-xs">Requerimientos</p>
        <p class="text-2xl font-bold">4</p>
        <p class="text-xs text-gray-400 mt-1">2 completados</p>
      </div>

      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4">
        <p class="text-gray-500 text-xs">Actividades</p>
        <p class="text-2xl font-bold">7</p>
        <p class="text-xs text-gray-400 mt-1">5 completadas</p>
      </div>

      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4">
        <p class="text-gray-500 text-xs">Equipo</p>
        <p class="text-2xl font-bold">5</p>
        <p class="text-xs text-gray-400 mt-1">5 disponibles</p>
      </div>
    </div>

    <!-- Tabs: Requirements | Activities | Team | Products | Reports -->
    <div class="border-b">
      <div class="flex gap-6 text-sm">
        <a href="/projects/detail?tab=requirements" class="pb-2 border-b-2 border-blue-600 font-medium text-blue-600">Requerimientos</a>
        <a href="/projects/detail?tab=actas" class="pb-2 border-b-2 border-transparent text-gray-500 hover:text-gray-700">Actas</a>
        <a href="/projects/detail?tab=activities" class="pb-2 border-b-2 border-transparent text-gray-500 hover:text-gray-700">Actividades</a>
        <a href="/projects/detail?tab=products" class="pb-2 border-b-2 border-transparent text-gray-500 hover:text-gray-700">Productos</a>
        <a href="/projects/detail?tab=team" class="pb-2 border-b-2 border-transparent text-gray-500 hover:text-gray-700">Equipo</a>
        <a href="/projects/detail?tab=reports" class="pb-2 border-b-2 border-transparent text-gray-500 hover:text-gray-700">Reportes</a>
      </div>
    </div>

    <!-- REQUIREMENTS TAB -->
    <div class="space-y-3">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Requerimientos del Proyecto</h2>
        <button class="text-blue-600 text-sm font-medium hover:underline">+ Agregar</button>
      </div>

      <!-- Req 1: Generated -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <div class="flex items-start justify-between">
          <div class="flex items-start gap-3">
            <input type="checkbox" checked class="mt-1.5 w-4 h-4">
            <div>
              <h3 class="font-medium flex items-center gap-2">
                ✅ Generación de facturas
                <span class="text-xs bg-red-100 text-red-700 px-1.5 py-0.5 rounded">Alta</span>
                <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">Compl.</span>
              </h3>
              <p class="text-sm text-gray-500 mt-1">Módulo principal para crear y emitir facturas electrónicas.</p>
            </div>
          </div>
          <div class="flex gap-2 text-sm">
            <a href="#" class="text-blue-600 hover:underline">3 actividades</a>
            <span class="text-gray-300">|</span>
            <a href="#" class="text-blue-600 hover:underline">1 acta</a>
            <span class="text-gray-300">|</span>
            <a href="#" class="text-blue-600 hover:underline">2 productos</a>
          </div>
        </div>
      </div>

      <!-- Req 2: Completed -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <div class="flex items-start gap-3">
          <input type="checkbox" checked class="mt-1.5 w-4 h-4">
          <div>
            <h3 class="font-medium flex items-center gap-2">
              ✅ Integración con SAT
              <span class="text-xs bg-red-100 text-red-700 px-1.5 py-0.5 rounded">Alta</span>
              <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">Compl.</span>
            </h3>
            <p class="text-sm text-gray-500 mt-1">Conexión y firma digital con el SAT vía API CFDI 4.0.</p>
          </div>
        </div>
      </div>

      <!-- Req 3: In Progress -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <div class="flex items-start gap-3">
          <input type="checkbox" class="mt-1.5 w-4 h-4">
          <div>
            <h3 class="font-medium flex items-center gap-2">
              ⏳ Dashboard financiero
              <span class="text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded">Media</span>
              <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">En Progreso</span>
            </h3>
            <p class="text-sm text-gray-500 mt-1">Vista de ingresos, gastos y estadísticas del sistema.</p>
          </div>
        </div>
      </div>

      <!-- Req 4: Pending -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-5">
        <div class="flex items-start gap-3">
          <input type="checkbox" class="mt-1.5 w-4 h-4">
          <div>
            <h3 class="font-medium flex items-center gap-2">
              📋 Reportes mensuales
              <span class="text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded">Media</span>
              <span class="text-xs bg-gray-100 text-gray-700 px-1.5 py-0.5 rounded">Pendiente</span>
            </h3>
            <p class="text-sm text-gray-500 mt-1">Generación automática de reportes para contabilidad.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
      <a href="/projects/detail?tab=activities" class="bg-white dark:bg-gray-900 rounded-xl border p-4 text-center hover:border-blue-300 transition cursor-pointer">
        <p class="text-2xl">📋</p>
        <p class="text-sm font-medium mt-2">Ver Actividades (7)</p>
      </a>
      <a href="/projects/detail?tab=team" class="bg-white dark:bg-gray-900 rounded-xl border p-4 text-center hover:border-blue-300 transition cursor-pointer">
        <p class="text-2xl">👥</p>
        <p class="text-sm font-medium mt-2">Ver Equipo (5)</p>
      </a>
      <a href="/projects/detail?tab=reports" class="bg-white dark:bg-gray-900 rounded-xl border p-4 text-center hover:border-blue-300 transition cursor-pointer">
        <p class="text-2xl">📊</p>
        <p class="text-sm font-medium mt-2">Ver Reportes</p>
      </a>
      <a href="#" class="bg-white dark:bg-gray-900 rounded-xl border p-4 text-center hover:border-blue-300 transition cursor-pointer">
        <p class="text-2xl">📄</p>
        <p class="text-sm font-medium mt-2">Ver Actas</p>
      </a>
    </div>
  </div>
</Layout>
