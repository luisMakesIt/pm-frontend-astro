---
import Layout from '../../layouts/Layout.astro';

const title = 'Proyectos';
---

<Layout title={title}>
  <div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Proyectos</h1>
        <p class="text-gray-500 text-sm mt-1">Gestiona tus proyectos de software</p>
      </div>
      <button onclick="document.getElementById('modal-create').classList.remove('hidden')" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition">
        + Nuevo Proyecto
      </button>
    </div>

    <div id="projects-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <p class="text-gray-500 text-sm">Cargando proyectos...</p>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="modal-create" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Crear Proyecto</h3>
      <form id="form-create" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Descripción</label>
          <textarea name="description" rows="3" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Cliente</label>
          <input type="text" name="client_name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado</label>
          <select name="status" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
            <option value="planificacion">Planificación</option>
            <option value="activo">Activo</option>
            <option value="en_progreso">En Progreso</option>
            <option value="completado">Completado</option>
            <option value="pausado">Pausado</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Fecha Inicio</label>
          <input type="date" name="start_date" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Fecha Fin</label>
          <input type="date" name="end_date" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div id="create-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition">Crear</button>
          <button type="button" onclick="document.getElementById('modal-create').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="modal-edit" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Editar Proyecto</h3>
      <form id="form-edit" class="space-y-4">
        <input type="hidden" name="id" id="edit-id">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" name="name" id="edit-name" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Descripción</label>
          <textarea name="description" id="edit-description" rows="3" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Cliente</label>
          <input type="text" name="client_name" id="edit-client_name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Estado</label>
          <select name="status" id="edit-status" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
            <option value="planificacion">Planificación</option>
            <option value="activo">Activo</option>
            <option value="en_progreso">En Progreso</option>
            <option value="completado">Completado</option>
            <option value="pausado">Pausado</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Fecha Inicio</label>
          <input type="date" name="start_date" id="edit-start_date" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Fecha Fin</label>
          <input type="date" name="end_date" id="edit-end_date" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div id="edit-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition">Guardar</button>
          <button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    var API = 'http://zasm8vmm79eejamdbgx3zwda.144.217.163.180.sslip.io/api';

    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    async function loadProjects() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects', {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        var container = document.getElementById('projects-list');
        if (json.success && json.data) {
          var projects = json.data;
          if (projects.length === 0) {
            container.innerHTML = '<div class="col-span-full text-center text-gray-500 py-8">No hay proyectos. Crea uno nuevo.</div>';
            return;
          }
          container.innerHTML = projects.map(function(p) {
            var statusColors = {
              'completado': 'bg-green-100 text-green-700',
              'activo': 'bg-blue-100 text-blue-700',
              'en_progreso': 'bg-blue-100 text-blue-700',
              'planificacion': 'bg-yellow-100 text-yellow-700',
              'pausado': 'bg-gray-100 text-gray-700'
            };
            var sc = statusColors[p.status] || 'bg-gray-100 text-gray-700';
            var progress = p.progreso || 0;
            return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-5">' +
              '<div class="flex items-start justify-between mb-3">' +
              '<h3 class="font-semibold">' + (p.name || 'Sin nombre') + '</h3>' +
              '<span class="' + sc + ' text-xs px-2 py-1 rounded">' + (p.status || 'activo') + '</span></div>' +
              '<p class="text-sm text-gray-500 mb-3">' + (p.description || 'Sin descripción') + '</p>' +
              '<div class="w-full bg-gray-200 rounded-full h-2 mb-3"><div class="bg-blue-500 h-2 rounded-full" style="width:' + progress + '%"></div></div>' +
              '<p class="text-xs text-gray-400 mb-3">' + progress + '% completado</p>' +
              '<div class="flex gap-2">' +
              '<a href="/projects/' + p.id + '" class="text-blue-600 text-sm hover:underline">Ver detalle</a>' +
              '<button onclick="editProject(' + p.id + ')" class="text-gray-600 text-sm hover:underline">Editar</button>' +
              '<button onclick="deleteProject(' + p.id + ')" class="text-red-600 text-sm hover:underline">Eliminar</button>' +
              '</div></div>';
          }).join('');
        }
      } catch(e) {
        document.getElementById('projects-list').innerHTML = '<div class="col-span-full text-center text-red-500 py-8">Error al cargar proyectos</div>';
      }
    }

    document.getElementById('form-create').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken();
      if (!token) return;
      var formData = new FormData(this);
      var data = {};
      formData.forEach(function(v, k) { data[k] = v; });
      var errEl = document.getElementById('create-error');
      try {
        var res = await fetch(API + '/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(data)
        });
        var json = await res.json();
        if (json.success) {
          document.getElementById('modal-create').classList.add('hidden');
          this.reset();
          loadProjects();
        } else {
          errEl.textContent = json.message || 'Error al crear proyecto';
          errEl.classList.remove('hidden');
        }
      } catch(err) {
        errEl.textContent = 'Error de conexión: ' + err.message;
        errEl.classList.remove('hidden');
      }
    });

    async function editProject(id) {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + id, {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        if (json.success && json.data) {
          var p = json.data;
          document.getElementById('edit-id').value = p.id;
          document.getElementById('edit-name').value = p.name || '';
          document.getElementById('edit-description').value = p.description || '';
          document.getElementById('edit-client_name').value = p.client_name || '';
          document.getElementById('edit-status').value = p.status || 'activo';
          document.getElementById('edit-start_date').value = (p.start_date || '').split('T')[0];
          document.getElementById('edit-end_date').value = (p.end_date || '').split('T')[0];
          document.getElementById('modal-edit').classList.remove('hidden');
        }
      } catch(e) {
        alert('Error al cargar proyecto');
      }
    }

    document.getElementById('form-edit').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken();
      if (!token) return;
      var id = document.getElementById('edit-id').value;
      var formData = new FormData(this);
      var data = {};
      formData.forEach(function(v, k) { if (k !== 'id') data[k] = v; });
      var errEl = document.getElementById('edit-error');
      try {
        var res = await fetch(API + '/projects/' + id + '?_method=PUT', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(data)
        });
        var json = await res.json();
        if (json.success) {
          document.getElementById('modal-edit').classList.add('hidden');
          loadProjects();
        } else {
          errEl.textContent = json.message || 'Error al actualizar';
          errEl.classList.remove('hidden');
        }
      } catch(err) {
        errEl.textContent = 'Error: ' + err.message;
        errEl.classList.remove('hidden');
      }
    });

    async function deleteProject(id) {
      if (!confirm('¿Eliminar este proyecto?')) return;
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + id, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        if (res.ok) {
          loadProjects();
        } else {
          alert('Error al eliminar proyecto');
        }
      } catch(e) {
        alert('Error de conexión');
      }
    }

    loadProjects();
  </script>
</Layout>
