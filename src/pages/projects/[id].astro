---
import Layout from '../../layouts/Layout.astro';
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

export function getStaticPaths() {
  return [{ params: { id: '1' } }];
}

const { id } = Astro.params;
const title = 'Detalle del Proyecto';
---

<Layout title={title}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <a href="/projects" class="text-blue-600 text-sm hover:underline mb-2 inline-block">← Volver a proyectos</a>
        <h1 class="text-2xl font-bold" id="project-name">Cargando...</h1>
        <p class="text-gray-500 text-sm mt-1" id="project-desc"></p>
      </div>
      <div class="flex gap-2">
        <button onclick="document.getElementById('modal-req').classList.remove('hidden')" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition">+ Requerimiento</button>
        <button onclick="document.getElementById('modal-member').classList.remove('hidden')" class="border px-4 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">+ Miembro</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">
        <p class="text-gray-500 text-xs">Estado</p>
        <p class="font-medium mt-1" id="project-status">-</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">
        <p class="text-gray-500 text-xs">Progreso</p>
        <p class="font-medium mt-1" id="project-progress">-</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">
        <p class="text-gray-500 text-xs">Fecha Inicio</p>
        <p class="font-medium mt-1" id="project-start">-</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">
        <p class="text-gray-500 text-xs">Fecha Fin</p>
        <p class="font-medium mt-1" id="project-end">-</p>
      </div>
    </div>

    <div class="border-b">
      <nav class="flex gap-4">
        <button onclick="switchTab('reqs')" id="tab-reqs" class="py-2 px-4 border-b-2 border-blue-500 font-medium text-sm">Requerimientos</button>
        <button onclick="switchTab('members')" id="tab-members" class="py-2 px-4 border-b-2 border-transparent text-sm text-gray-500">Equipo</button>
      </nav>
    </div>

    <div id="tab-content-reqs" class="space-y-4">
      <div id="reqs-list" class="space-y-3">
        <p class="text-gray-500 text-sm">Cargando requerimientos...</p>
      </div>
    </div>

    <div id="tab-content-members" class="hidden space-y-4">
      <div id="members-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-gray-500 text-sm">Cargando miembros...</p>
      </div>
    </div>
  </div>

  <!-- Create Requirement Modal -->
  <div id="modal-req" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Nuevo Requerimiento</h3>
      <form id="form-req" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Título</label>
          <input type="text" name="title" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Descripción</label>
          <textarea name="description" rows="3" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Prioridad</label>
          <select name="priority" class="w-full px-4 py-2 border rounded-lg">
            <option value="alta">Alta</option>
            <option value="media" selected>Media</option>
            <option value="baja">Baja</option>
          </select>
        </div>
        <div id="req-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition">Crear</button>
          <button type="button" onclick="document.getElementById('modal-req').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add Member Modal -->
  <div id="modal-member" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 transition-opacity duration-200" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white dark:bg-gray-900 rounded-xl border p-6 w-full max-w-md transition-transform duration-200">
      <h3 class="text-lg font-bold mb-4">Agregar Miembro al Equipo</h3>
      <form id="form-member" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" name="email" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Rol</label>
          <select name="role" class="w-full px-4 py-2 border rounded-lg">
            <option value="developer">Desarrollador</option>
            <option value="tech_lead">Líder Técnico</option>
            <option value="tester">QA / Tester</option>
            <option value="designer">Diseñador</option>
          </select>
        </div>
        <div id="member-error" class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg"></div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition">Agregar</button>
          <button type="button" onclick="document.getElementById('modal-member').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ API_BASE }}>
    var API = API_BASE + '/api';
    var PROJECT_ID = window.location.pathname.split('/').filter(Boolean).pop() || '1';

    function esc(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    function getToken() {
      var t = localStorage.getItem('pm_token');
      if (!t) { window.location.href = '/login'; return null; }
      return t;
    }

    window.switchTab = function(tab) {
      var reqsContent = document.getElementById('tab-content-reqs');
      var membersContent = document.getElementById('tab-content-members');
      var tabReqs = document.getElementById('tab-reqs');
      var tabMembers = document.getElementById('tab-members');
      if (tab === 'reqs') {
        reqsContent.classList.remove('hidden');
        membersContent.classList.add('hidden');
        tabReqs.classList.add('border-blue-500', 'font-medium');
        tabReqs.classList.remove('border-transparent', 'text-gray-500');
        tabMembers.classList.add('border-transparent', 'text-gray-500');
        tabMembers.classList.remove('border-blue-500', 'font-medium');
      } else {
        membersContent.classList.remove('hidden');
        reqsContent.classList.add('hidden');
        tabMembers.classList.add('border-blue-500', 'font-medium');
        tabMembers.classList.remove('border-transparent', 'text-gray-500');
        tabReqs.classList.add('border-transparent', 'text-gray-500');
        tabReqs.classList.remove('border-blue-500', 'font-medium');
      }
    }

    async function loadProject() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + PROJECT_ID, {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        if (json.success && json.data) {
          var p = json.data;
          document.getElementById('project-name').textContent = p.name || 'Sin nombre';
          document.getElementById('project-desc').textContent = p.description || '';
          document.getElementById('project-status').textContent = p.status || '-';
          document.getElementById('project-progress').textContent = (p.progreso || 0) + '%';
          document.getElementById('project-start').textContent = (p.start_date || '-').split('T')[0];
          document.getElementById('project-end').textContent = (p.end_date || '-').split('T')[0];
        }
      } catch(e) {
        document.getElementById('project-name').textContent = 'Error al cargar';
      }
    }

    async function loadRequirements() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + PROJECT_ID + '/requirements', {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        var container = document.getElementById('reqs-list');
        if (json.success && json.data) {
          var reqs = Array.isArray(json.data) ? json.data : [json.data];
          if (reqs.length === 0) {
            container.innerHTML = '<p class="text-gray-500 text-sm">No hay requerimientos. Crea uno nuevo.</p>';
            return;
          }
          container.innerHTML = reqs.map(function(r) {
            var prioColors = { 'alta': 'bg-red-100 text-red-700', 'media': 'bg-yellow-100 text-yellow-700', 'baja': 'bg-green-100 text-green-700' };
            var pc = prioColors[r.priority] || 'bg-gray-100 text-gray-700';
            var status = r.status || 'pendiente';
            return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">' +
              '<div class="flex items-start justify-between mb-2">' +
              '<h4 class="font-medium">' + esc(r.title || 'Sin título') + '</h4>' +
              '<div class="flex gap-1"><span class="' + pc + ' text-xs px-2 py-1 rounded">' + esc(r.priority || 'media') + '</span>' +              '<span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">' + esc(status) + '</span></div></div>' +
              '<p class="text-sm text-gray-500 mb-2">' + esc(r.description || '') + '</p>' +
              '<div class="flex gap-2">' +
              '<a href="/requerimientos" class="text-blue-600 text-sm hover:underline">Ver actividades</a>' +
              '<button onclick="deleteReq(' + r.id + ')" class="text-red-600 text-sm hover:underline">Eliminar</button>' +
              '</div></div>';
          }).join('');
        }
      } catch(e) {
        document.getElementById('reqs-list').innerHTML = '<p class="text-red-500 text-sm">Error al cargar requerimientos</p>';
      }
    }

    async function loadMembers() {
      var token = getToken();
      if (!token) return;
      try {
        var res = await fetch(API + '/projects/' + PROJECT_ID + '/team-members', {
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        var json = await res.json();
        var container = document.getElementById('members-list');
        if (json.success && json.data) {
          var members = Array.isArray(json.data) ? json.data : [json.data];
          if (members.length === 0) {
            container.innerHTML = '<p class="text-gray-500 text-sm">No hay miembros. Agrega uno.</p>';
            return;
          }
          container.innerHTML = members.map(function(m) {
            var roleColors = { 'developer': 'bg-blue-100 text-blue-700', 'tech_lead': 'bg-purple-100 text-purple-700', 'tester': 'bg-green-100 text-green-700', 'designer': 'bg-pink-100 text-pink-700' };
            var rc = roleColors[m.role] || 'bg-gray-100 text-gray-700';
            return '<div class="bg-white dark:bg-gray-900 rounded-xl border p-4 transition-shadow hover:shadow-md">' +
              '<div class="flex items-center gap-3">' +
              '<div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">' + esc((m.name || '?').charAt(0).toUpperCase()) + '</div>' +
              '<div><h4 class="font-medium">' + esc(m.name || 'Sin nombre') + '</h4>' +
              '<p class="text-sm text-gray-500">' + esc(m.email || '') + '</p></div></div>' +
              '<div class="mt-3 flex items-center justify-between">' +
              '<span class="' + rc + ' text-xs px-2 py-1 rounded">' + esc(m.role || '-') + '</span>' +
              '<button onclick="deleteMember(' + m.id + ')" class="text-red-600 text-sm hover:underline">Eliminar</button>' +
              '</div></div>';
          }).join('');
        }
      } catch(e) {
        document.getElementById('members-list').innerHTML = '<p class="text-red-500 text-sm">Error al cargar miembros</p>';
      }
    }

    document.getElementById('form-req').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken();
      if (!token) return;
      var formData = new FormData(this);
      var data = {};
      formData.forEach(function(v, k) { data[k] = v; });
      var errEl = document.getElementById('req-error');
      try {
        var res = await fetch(API + '/projects/' + PROJECT_ID + '/requirements', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(data)
        });
        var json = await res.json();
        if (json.success) {
          document.getElementById('modal-req').classList.add('hidden');
          this.reset();
          loadRequirements();
        } else {
          errEl.textContent = json.message || 'Error al crear requerimiento';
          errEl.classList.remove('hidden');
        }
      } catch(err) {
        errEl.textContent = 'Error: ' + err.message;
        errEl.classList.remove('hidden');
      }
    });

    document.getElementById('form-member').addEventListener('submit', async function(e) {
      e.preventDefault();
      var token = getToken();
      if (!token) return;
      var formData = new FormData(this);
      var data = {};
      formData.forEach(function(v, k) { data[k] = v; });
      var errEl = document.getElementById('member-error');
      try {
        var res = await fetch(API + '/projects/' + PROJECT_ID + '/team-members', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(data)
        });
        var json = await res.json();
        if (json.success) {
          document.getElementById('modal-member').classList.add('hidden');
          this.reset();
          loadMembers();
        } else {
          errEl.textContent = json.message || 'Error al agregar miembro';
          errEl.classList.remove('hidden');
        }
      } catch(err) {
        errEl.textContent = 'Error: ' + err.message;
        errEl.classList.remove('hidden');
      }
    });

    window.deleteReq = async function(id) {
      if (!confirm('¿Eliminar este requerimiento?')) return;
      var token = getToken();
      if (!token) return;
      try {
        await fetch(API + '/projects/' + PROJECT_ID + '/requirements/' + id, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        loadRequirements();
      } catch(e) { alert('Error al eliminar'); }
    }

    window.deleteMember = async function(id) {
      if (!confirm('¿Eliminar este miembro?')) return;
      var token = getToken();
      if (!token) return;
      try {
        await fetch(API + '/projects/' + PROJECT_ID + '/team-members/' + id, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json', 'Authorization': 'Bearer ' + token }
        });
        loadMembers();
      } catch(e) { alert('Error al eliminar'); }
    }

    loadProject();
    loadRequirements();
    loadMembers();
  </script>
</Layout>
