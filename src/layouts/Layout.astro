---
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  sidebar?: boolean;
}

const { title = 'PM System', sidebar = true } = Astro.props;
const { children } = Astro.slots;
---

<!doctype html>
<html lang="es" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — PM System</title>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
    {sidebar ? <Sidebar>{children}</Sidebar> : <div class="h-screen overflow-auto">{children}</div>}

    <script is:inline>
      const html = document.documentElement;
      const theme = localStorage.getItem('theme') || 'light';
      html.className = theme;
      window.__toggleTheme = function() {
        const isDark = html.className.includes('dark');
        html.className = isDark ? 'light' : 'dark';
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      };
    </script>
  </body>
</html>
