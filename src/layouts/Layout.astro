---
import Sidebar from '../components/Sidebar.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  sidebar?: boolean;
}

const { title = 'PM System', sidebar = true } = Astro.props;
---

<!doctype html>
<html lang="es" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — PM System</title>
    <script is:inline>
      (function () {
        var path = window.location.pathname;
        var isLoginPage = path === '/login' || path === '/login/';
        if (!isLoginPage) {
          var token = localStorage.getItem('pm_token');
          if (!token) {
            window.location.href = '/login';
            return;
          }
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
    {sidebar ? <Sidebar><slot /></Sidebar> : <div class="h-screen overflow-auto"><slot /></div>}

    <script is:inline>
      if (typeof window !== 'undefined') {
        const html = document.documentElement;
        const theme = localStorage.getItem('theme') || 'light';
        html.className = theme;
        window.__toggleTheme = function() {
          const isDark = html.className.includes('dark');
          html.className = isDark ? 'light' : 'dark';
          localStorage.setItem('theme', isDark ? 'light' : 'dark');
        };
        // Populate user dropdown
        (function() {
          try {
            var userJson = localStorage.getItem('pm_user');
            if (userJson) {
              var user = JSON.parse(userJson);
              var name = user.name || 'Usuario';
              var email = user.email || '-';
              var initialEl = document.getElementById('user-initial');
              var nameEl = document.getElementById('dd-user-name');
              var emailEl = document.getElementById('dd-user-email');
              if (initialEl) initialEl.textContent = name.charAt(0).toUpperCase();
              if (nameEl) nameEl.textContent = name;
              if (emailEl) emailEl.textContent = email;
            }
          } catch(e) {}
        })();
        // Close dropdown on outside click
        document.addEventListener('click', function(e) {
          var wrapper = document.getElementById('user-dropdown-wrapper');
          var menu = document.getElementById('user-dropdown-menu');
          if (wrapper && menu && !wrapper.contains(e.target)) {
            menu.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>
